# ── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_URL=https://your-company.atlassian.net
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_CLOUD=false                        # false for Server / Data Center

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=confluence_graphrag

# ── Ingestion behavior ────────────────────────────────────────────────────────
INCREMENTAL_POLL_INTERVAL_HOURS=24           # D5: how often to poll for changes
CONFLUENCE_PAGE_LIMIT=50                     # pages per Confluence API call
MAX_RETRY_COUNT=3

# ── Gemini (Google AI) ───────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key-here     # enables /search and embeddings
