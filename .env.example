# ── Confluence ───────────────────────────────────────────────────────────────
CONFLUENCE_URL=https://your-company.atlassian.net
CONFLUENCE_USERNAME=your-email@company.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_CLOUD=false                        # false for Server / Data Center
CONFLUENCE_VERIFY_SSL=true                    # set false to disable SSL verification (not recommended)
CONFLUENCE_CA_BUNDLE=                         # path to custom CA bundle file (optional)

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=confluence_graphrag

# ── Ingestion behavior ────────────────────────────────────────────────────────
INCREMENTAL_POLL_INTERVAL_HOURS=24           # D5: how often to poll for changes
CONFLUENCE_PAGE_LIMIT=50                     # pages per Confluence API call
MAX_RETRY_COUNT=3

# ── Gemini / Vertex AI ───────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key-here     # enables /search and embeddings
GCP_PROJECT=your-gcp-project-id                # required for Vertex AI; leave blank for API-key mode
GCP_LOCATION=us-central1                       # Vertex AI region
VERTEX_AI_ENDPOINT=                            # custom Vertex AI endpoint (optional)

# ── Attachment Processor (Stage 3A) ──────────────────────────────────────────
ENABLE_VISION=true                             # false to skip ALL image processing:
                                               #   - standalone image attachments (.png, .jpg, ...)
                                               #   - images embedded inside PDF pages
                                               #   - images embedded inside PPTX slides
                                               #   - scanned (fully rasterized) PDF pages
VISION_MODEL=gemini-2.5-flash
MAX_ATTACHMENT_SIZE_BYTES=26214400             # 25 MB — files larger than this are skipped
ATTACHMENT_CONCURRENCY=4                       # max parallel downloads/extractions per page
CHUNK_SIZE=1000                                # attachment text chunk size (characters)
CHUNK_OVERLAP=150                              # overlap between consecutive chunks
